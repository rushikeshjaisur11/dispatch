# App-level credentials (maintainer-provided), never per-user secrets.
# Copy this file to .env and fill in your own values. .env is gitignored.

# Google Cloud OAuth 2.0 client (Desktop App type, Calendar API scope enabled).
# Used for the Google Calendar sync PKCE flow — see electron/googleCalendarManager.cjs.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# Supabase project — used for cross-device sync and magic-link/OAuth sign-in.
# Run supabase/sync_schema.sql in the project's SQL editor before first use.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
